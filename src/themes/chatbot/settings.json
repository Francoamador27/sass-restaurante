{
  "theme": {
    "primaryColor": "#343541",
    "secondaryColor": "#19C37D",
    "fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', 'Fira Sans', 'Droid Sans', 'Helvetica Neue', sans-serif",
    "showHeader": true,
    "showFooter": false,
    "embedded": false
  },
  
  "tooltip": {
    "mode": "CLOSE",
    "text": "¡Chateá con nosotros! 😊"
  },
  
  "chatButton": {
    "icon": "data:image/png;base64,"
  },
  
  "header": {
    "title": "DentalCor Software",
    "showAvatar": true,
    "avatar": "data:image/png;base64,"
  },
  
  "chatWindow": {
    "showScrollbar": false,
    "autoJumpToBottom": false,
    "showMessagePrompt": true,
    "messagePromptText": "Nuevos mensajes ↓",
    "messagePromptOffset": 30
  },
  
"chatInput": {
  "disabled": true,              
  "enabledAutoFocus": false,      
  "allowNewline": false,
  "enabledPlaceholderText": "Escribí tu mensaje...",
  "disabledPlaceholderText": "Procesando...",
  "botDelay": 1000,
  "blockSpam": true,
  "sendOptionOutput": true
}

,
  
  "botBubble": {
    "animate": true,
    "showAvatar": true,
    "avatar": "data:image/png;base64,",
    "simStream": true,
    "streamSpeed": 30
  },
  
  "userBubble": {
    "animate": true,
    "showAvatar": false,
    "simStream": false
  },
  
  "chatHistory": {
    "disabled": false,
    "maxEntries": 30,
    "storageKey": "decoimanes_chat_history",
    "viewChatHistoryButtonText": "Cargar historial ⟳",
    "chatHistoryLineBreakText": "----- Conversación Anterior -----",
    "autoLoad": false
  },
  
  "notification": {
    "disabled": false,
    "defaultToggledOn": true,
    "volume": 0.2,
    "showCount": true
  },
  
  "emoji": {
    "disabled": false,
    "list": ["😀", "😊", "👍", "❤️", "🎉", "✅", "📦", "🚚", "💬", "⭐"]
  },
  
  "fileAttachment": {
    "disabled": false,
    "multiple": true,
    "accept": ".png, .jpg, .jpeg, .pdf"
  },
  
  "footer": {
    "text": "Powered by Codenix"
  }
}